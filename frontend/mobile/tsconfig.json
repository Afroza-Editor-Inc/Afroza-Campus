{
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",
    "jsx": "react-native",
    "strict": true,
    "moduleResolution": "bundler",
    "allowJs": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": "./",
    "lib": [
      "DOM",
      "ESNext"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "**/*.stories.tsx",
    "**/*.stories.ts"
  ],
  "extends": "expo/tsconfig.base"
}
